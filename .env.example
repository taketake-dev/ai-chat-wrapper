# ==============================================================================
# Example .env file for ai-chat-wrapper
# Copy to .env and set appropriate values for your environment:
# cp .env.example .env
# ============================================================================

# Gemini API key (if using Gemini client)
GEMINI_API_KEY=

# Optional system instruction used by demo script
SYSTEM_INSTRUCTION=

# Optional: model path for local models (if used)
MODEL_PATH=path/to/your/model.safetensors

# Output directory used by some tools
OUTPUT_DIR=output
